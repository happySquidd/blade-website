---
import { getCollection } from "astro:content";
import Hero from "@/components/Hero.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Section from "@/components/Section.astro";
import BlogPostCard from "@/components/BlogPostCard.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import Layout from "@/layouts/Layout.astro";
import { KNOWN_TECH, ABOUT_ME } from "@/consts";
import { getProjects } from "@/lib/projects";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allProjects = await getProjects();
const projects = allProjects.slice(0, 3);
---

<Layout>
  <Hero />

  <Section
    title="Projects"
    className={"bg-gradient-to-b from-black/70 from-[5%] to-black via-black"}
  >
    {
      projects.length > 0 ? (
        <>
          <div class="w-full grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {projects.map((project) => (
              <ProjectCard
                name={project.name}
                description={project.description}
                url={project.url}
                homepage={project.homepage}
                stars={project.stars}
                language={project.language}
              />
            ))}
          </div>
          {allProjects.length > projects.length && (
            <div class="w-full grid place-items-center mt-10">
              <a
                href="/projects"
                class="border-2 border-white px-6 pt-3 pb-2 leading-none inline-flex items-center gap-3 hover:bg-white hover:text-black transition-all ease-in-out"
              >
                View all {allProjects.length} projects
                <span>❯</span>
              </a>
            </div>
          )}
        </>
      ) : (
        <div class="w-full grid place-items-center">
          <div class="max-w-2xl border-2 border-white/40 rounded-lg p-6 text-center opacity-80">
            <p>
              <span class="text-white/60 mr-2">❯</span>
              No projects yet. Add them to <code>PROJECTS</code> in{" "}
              <code>src/consts.ts</code>, or set <code>GITHUB_USERNAME</code> to
              auto-load your repos.
            </p>
          </div>
        </div>
      )
    }
  </Section>

  <Section
    title="Blog"
    className={"bg-gradient-to-b from-black/70 from-[5%] to-black via-black"}
  >
    <div class="w-full grid grid-cols-1 md:grid-cols-2 gap-4">
      {
        posts.map((post) => (
          <BlogPostCard
            slug={post.id}
            title={post.data.title}
            excerpt={post.data.description}
            date={post.data.pubDate}
          />
        ))
      }
    </div>
  </Section>

  <Section title="Tech" full_screen={false}>
    <div class="w-full grid place-items-center">
      <div
        class="w-full gap-4 flex flex-wrap px-3 max-w-xl text-lg justify-center"
      >
        {KNOWN_TECH.map((x) => <Breadcrumb title={x} />)}
      </div>
    </div>
  </Section>

  <Section title="About">
    <div class="w-full grid place-items-center">
      <div
        class="max-w-4xl text-xl md:text-lg opacity-90 text-center justify-evenly"
      >
        <p>{ABOUT_ME}</p>
      </div>
    </div>
  </Section>
</Layout>
