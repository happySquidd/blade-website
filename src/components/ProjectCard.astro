---
type Props = {
  name: string;
  description: string | null;
  url: string;
  homepage?: string | null;
  stars: number;
  language: string | null;
};

const { name, description, url, homepage, stars, language } = Astro.props;
---

<div
  class="w-full mx-auto bg-gradient-to-br relative pb-5 min-h-[220px] flex flex-col from-white/[0.001] to-white/[0.01] border-2 border-white rounded-lg overflow-hidden"
>
  <div class="flex items-center justify-start px-4 py-2 bg-white/95">
    <div class="flex space-x-2">
      <div class="w-3 h-3 rounded-full bg-black"></div>
      <div class="w-3 h-3 rounded-full bg-black"></div>
      <div class="w-3 h-3 rounded-full bg-black"></div>
    </div>
  </div>

  <div class="p-6 tracking-wider flex flex-col flex-1">
    <a href={url} target="_blank" rel="noopener noreferrer" class="block group">
      <h2 class="text-xl font-medium text-white mb-2 break-all">
        <span class="ba text-white/70 mr-2">❯</span>
        {name}
      </h2>
      <p class="text-white font-medium tracking-widest text-sm mb-4">
        [{language ?? "code"}]{stars > 0 && ` ★ ${stars}`}
      </p>
      <p class="text-white/80 text-sm font-thin mb-4 line-clamp-2">
        {description ?? "No description provided."}
      </p>
    </a>

    <div class="mt-auto flex flex-wrap gap-x-6 gap-y-2">
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-white font-medium inline-flex items-center group/link underline underline-offset-8 hover:underline-offset-4 transition-all ease-in-out"
      >
        View repo
        <svg
          class="w-4 h-4 ml-2 transform group-hover/link:translate-x-1 transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width={2}
            d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
      {
        homepage && (
          <a
            href={homepage}
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/80 font-medium inline-flex items-center underline underline-offset-8 hover:underline-offset-4 hover:text-white transition-all ease-in-out"
          >
            Live
          </a>
        )
      }
    </div>
  </div>
</div>
